[advice]
	skippedCherryPicks = false
[alias]
	br = branch
	ci = commit
	last = log -n 1 --format=fuller
	ss = status
	wip = !git add . && git ci -m \"WIP\"
[commit]
	gpgsign = true
[core]
	editor = nvim
	ignorecase = false
	quotePath = false
[fetch]
	prune = true
[format]
	pretty = oneline
[init]
	defaultBranch = main
[log]
	abbrevCommit = true
[pull]
	rebase = false
[rebase]
	autoSquash = true
	autoStash = true
