[alias]
	br = branch
	ci = commit
	cil = !git commit --reset-author -c $(git log -n 1 --pretty=%H)
	co = checkout
	last = log -n 1
	ss = status
	wip = !git add . && git ci -m \"WIP\"
[commit]
	gpgsign = true
[core]
	editor = nvim
	ignorecase = false
[fetch]
	prune = true
[init]
	defaultBranch = main
[pull]
	rebase = false
